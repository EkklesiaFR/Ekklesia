rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getMemberData() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data;
    }

    function isMemberActive() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && getMemberData().status == "active";
    }

    function isAdminActive() {
      return isMemberActive()
        && getMemberData().role == "admin";
    }

    // =========================
    // MEMBERS (global)
    // =========================
    match /members/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdminActive());
      allow list: if isAdminActive();

      // Create: self only, pending + member only
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role == "member"
        && request.resource.data.status == "pending";

      // Self update: never role/status
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;

      // Admin can update/delete
      allow update, delete: if isAdminActive();
    }

    // =========================
    // ASSEMBLIES
    // =========================
    match /assemblies/{assemblyId} {

      allow read: if isMemberActive();

      // Interdire toute modif de l'assemblée si elle contient des résultats verrouillés
      allow update: if isAdminActive()
        && (!("results" in resource.data) || resource.data.results == null);

      match /members/{uid} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isAdminActive());
        allow write: if isAdminActive();
      }

      match /public/{docId} {
        allow read: if true;
        allow write: if isAdminActive();
      }

      match /votes/{voteId} {
        allow read: if isMemberActive();

        // ✅ Vote immuable après verrouillage
        // ✅ Quorum modifiable uniquement en draft
        // ✅ Empêcher la modification des résultats une fois écrits
        allow update: if isAdminActive()
          && resource.data.state != "locked"
          && (
            resource.data.state == "draft"
            || request.resource.data.quorumPct == resource.data.quorumPct
          );

        allow create, delete: if isAdminActive();

        match /ballots/{uid} {
          allow get, create, update: if isMemberActive()
            && request.auth.uid == uid
            && get(/databases/$(database)/documents/assemblies/$(assemblyId)/votes/$(voteId)).data.state == "open";

          allow list: if isAdminActive();
          allow delete: if false;
        }
      }
    }

    // =========================
    // PROJECTS
    // =========================
    match /projects/{projectId} {
      allow read: if isMemberActive();
      allow create: if isMemberActive();
      allow update, delete: if isAdminActive()
        || (isSignedIn()
            && request.auth.uid == resource.data.ownerUid
            && resource.data.status == "submitted");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}