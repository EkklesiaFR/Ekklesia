rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function rootMemberPath(uid) {
      return /databases/$(database)/documents/members/$(uid);
    }

    function assemblyMemberPath(assemblyId, uid) {
      return /databases/$(database)/documents/assemblies/$(assemblyId)/members/$(uid);
    }

    function rootExists() {
      return isSignedIn() && exists(rootMemberPath(request.auth.uid));
    }

    function mirrorExists(assemblyId) {
      return isSignedIn() && exists(assemblyMemberPath(assemblyId, request.auth.uid));
    }

    function rootData() {
      return get(rootMemberPath(request.auth.uid)).data;
    }

    function mirrorData(assemblyId) {
      return get(assemblyMemberPath(assemblyId, request.auth.uid)).data;
    }

    // ✅ Actif si ROOT active OU MIRROR active
    function isMemberActive(assemblyId) {
      return isSignedIn() && (
        (rootExists() && rootData().status == "active") ||
        (mirrorExists(assemblyId) && mirrorData(assemblyId).status == "active")
      );
    }

    // ✅ Admin actif si (ROOT admin+active) OU (MIRROR admin+active)
    function isAdminActive(assemblyId) {
      return isSignedIn() && (
        (rootExists() && rootData().status == "active" && rootData().role == "admin") ||
        (mirrorExists(assemblyId) && mirrorData(assemblyId).status == "active" && mirrorData(assemblyId).role == "admin")
      );
    }

    // Pour les collections root hors assembly (projects, members list)
    function isMemberActiveRoot() {
      return rootExists() && rootData().status == "active";
    }

    function isAdminActiveRoot() {
      return rootExists() && rootData().status == "active" && rootData().role == "admin";
    }

    // =========================
    // MEMBERS (root)
    // =========================
    match /members/{uid} {
      allow get: if isSelf(uid) || isAdminActiveRoot();
      allow list: if isAdminActiveRoot();

      allow create: if isSelf(uid)
        && request.resource.data.role == "member"
        && request.resource.data.status == "pending";

      allow update: if isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;

      allow update, delete: if isAdminActiveRoot();
    }

    // =========================
    // ASSEMBLIES
    // =========================
    match /assemblies/{assemblyId} {

      allow get, list: if isMemberActive(assemblyId);
      allow create, update, delete: if isAdminActive(assemblyId);

      // -------------------------
      // PRESENCE
      // -------------------------
      match /presence/{uid} {
        allow get, list: if isMemberActive(assemblyId);

        allow create, update: if isMemberActive(assemblyId)
          && isSelf(uid)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            "uid",
            "status",
            "sessionId",
            "lastSeenAt",
            "photoURL",
            "displayName"
          ])
          && (request.resource.data.status in ["online", "offline"])
          && (request.resource.data.lastSeenAt is timestamp);

        allow delete: if false;
      }

      // -------------------------
      // MEMBERS MIRROR
      // -------------------------
      match /members/{uid} {
        allow get: if isSelf(uid) || isAdminActive(assemblyId);
        allow list: if isAdminActive(assemblyId);
        allow create, update, delete: if isAdminActive(assemblyId);
      }

      // -------------------------
      // PUBLIC DOCS
      // -------------------------
      match /public/{docId} {
        allow get, list: if true;
        allow create, update, delete: if isAdminActive(assemblyId);
      }

      // =========================
      // VOTES
      // =========================
      match /votes/{voteId} {

        allow get, list: if isMemberActive(assemblyId);

        allow create: if isAdminActive(assemblyId);

        allow update: if isAdminActive(assemblyId)
          && resource.data.state != "locked"
          && (
            resource.data.state == "draft"
            || request.resource.data.quorumPct == resource.data.quorumPct
          );

        allow delete: if false;

        // =========================
        // BALLOTS
        // =========================
        match /ballots/{uid} {

          function voteDocPath() {
            return /databases/$(database)/documents/assemblies/$(assemblyId)/votes/$(voteId);
          }

          function voteIsOpen() {
            return exists(voteDocPath()) && get(voteDocPath()).data.state == "open";
          }

          allow get: if isMemberActive(assemblyId) && isSelf(uid);

          allow create, update: if isMemberActive(assemblyId)
            && isSelf(uid)
            && voteIsOpen();

          allow list: if isAdminActive(assemblyId);

          allow delete: if false;
        }
      }
    }

    // =========================
    // PROJECTS (root)
    // =========================
    match /projects/{projectId} {
      allow get, list: if isMemberActiveRoot();
      allow create: if isMemberActiveRoot();

      allow update, delete: if isAdminActiveRoot()
        || (
          isSignedIn()
          && request.auth.uid == resource.data.ownerUid
          && resource.data.status == "submitted"
        );
    }

    // =========================
    // DEFAULT DENY
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}