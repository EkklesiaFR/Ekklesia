rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================

    function isSignedIn() {
      return request.auth != null;
    }

    function memberDoc() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid));
    }

    function isMemberActive() {
      return isSignedIn()
        && memberDoc().exists()
        && memberDoc().data.status == "active";
    }

    function isAdminActive() {
      return isMemberActive()
        && memberDoc().data.role == "admin";
    }

    // =========================
    // MEMBERS
    // =========================

    match /members/{uid} {

      allow get: if isSignedIn() && (request.auth.uid == uid || isAdminActive());
      allow list: if isAdminActive();

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role == "member"
        && request.resource.data.status == "pending";

      // Self update without changing role/status
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;

      allow update, delete: if isAdminActive();
    }

    // =========================
    // ASSEMBLIES
    // =========================

    match /assemblies/{assemblyId} {

      allow read: if isMemberActive();

      match /members/{uid} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isAdminActive());
        allow write: if isAdminActive();
      }

      match /public/{docId} {
        allow read: if true;
        allow write: if isAdminActive();
      }

      // =========================
      // VOTES
      // =========================

      match /votes/{voteId} {

        allow read: if isMemberActive();

        allow create: if isAdminActive();

        // 🔒 VOTE IMMUTABLE AFTER LOCKED
        allow update: if isAdminActive()
          && resource.data.state != "locked"
          && (
            // quorumPct modifiable uniquement en draft
            resource.data.state == "draft"
            || request.resource.data.quorumPct == resource.data.quorumPct
          );

        allow delete: if false; // jamais supprimable

        // =========================
        // BALLOTS
        // =========================

        match /ballots/{uid} {

          function voteIsOpen() {
            return get(/databases/$(database)/documents/assemblies/$(assemblyId)/votes/$(voteId)).data.state == "open";
          }

          allow get: if isMemberActive()
            && request.auth.uid == uid;

          allow create, update: if isMemberActive()
            && request.auth.uid == uid
            && voteIsOpen();

          allow list: if isAdminActive();

          allow delete: if false; // jamais supprimable
        }
      }
    }

    // =========================
    // PROJECTS
    // =========================

    match /projects/{projectId} {

      allow read: if isMemberActive();

      allow create: if isMemberActive();

      allow update, delete: if isAdminActive()
        || (
          isSignedIn()
          && request.auth.uid == resource.data.ownerUid
          && resource.data.status == "submitted"
        );
    }

    // =========================
    // DEFAULT DENY
    // =========================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}